// Azadi-Teb resources: embedded Vazirmatn fonts + version info + manifest
#include <windows.h>

101 RCDATA "../fonts/Vazir-Regular.ttf"
102 RCDATA "../fonts/Vazir-Bold.ttf"

// v1.3.0: embedded background images (light / dark) for the welcome screen
103 RCDATA "../assets/bg_light.jpg"
104 RCDATA "../assets/bg_dark.jpg"

// v1.4.1: real (raster) print-action icons — white-on-alpha PNGs that are
// tinted to the theme accent at draw time (gpDrawTintedImageRes).
201 RCDATA "../assets/icons/ic_printer.png"
202 RCDATA "../assets/icons/ic_receipt.png"
203 RCDATA "../assets/icons/ic_shield.png"
204 RCDATA "../assets/icons/ic_last.png"
// v1.8.0: settings (gear) + calculator raster icons — white-on-alpha PNGs that
// are tinted to the theme accent at draw time so they read cleanly on BOTH the
// light and the dark theme.
205 RCDATA "../assets/icons/ic_settings.png"
206 RCDATA "../assets/icons/ic_calc.png"

1 24 "app.manifest"

VS_VERSION_INFO VERSIONINFO
 FILEVERSION 1,9,0,0
 PRODUCTVERSION 1,9,0,0
 FILEFLAGSMASK 0x3fL
 FILEFLAGS 0x0L
 FILEOS 0x40004L
 FILETYPE 0x1L
 FILESUBTYPE 0x0L
BEGIN
    BLOCK "StringFileInfo"
    BEGIN
        BLOCK "040904b0"
        BEGIN
            VALUE "CompanyName", "Azadi-Teb"
            VALUE "FileDescription", "Azadi-Teb Clinic Reception & Management System"
            VALUE "FileVersion", "1.9.0.0"
            VALUE "InternalName", "AzadiTeb"
            VALUE "OriginalFilename", "AzadiTeb.exe"
            VALUE "ProductName", "Azadi-Teb"
            VALUE "ProductVersion", "1.9.0"
        END
    END
    BLOCK "VarFileInfo"
    BEGIN
        VALUE "Translation", 0x409, 1200
    END
END
