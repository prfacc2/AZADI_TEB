<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="AzadiTeb.Reception.App"
             RequestedThemeVariant="Light">

  <Application.Resources>
    <FontFamily x:Key="Vazir">avares://AzadiTeb.Reception/Assets/Fonts#Vazirmatn</FontFamily>

    <!-- Palette lifted verbatim from admission.css so the Avalonia surface is
         visually identical to the retired HTML reception. -->
    <Color x:Key="BgColor">#eef2f8</Color>
    <Color x:Key="PanelColor">#ffffff</Color>
    <Color x:Key="InkColor">#0f2547</Color>
    <Color x:Key="MutedColor">#5a6b80</Color>
    <Color x:Key="LineColor">#c4d2e3</Color>
    <Color x:Key="AccentColor">#1f5fd6</Color>
    <Color x:Key="AccentColor2">#2f6fed</Color>
    <Color x:Key="AccentDark">#184dae</Color>
    <Color x:Key="DangerColor">#e11d48</Color>
    <Color x:Key="TealColor">#0ea5a4</Color>
    <Color x:Key="SoftColor">#f4f8fe</Color>
    <Color x:Key="HeadColor">#e8f1fc</Color>

    <SolidColorBrush x:Key="Bg" Color="{StaticResource BgColor}" />
    <SolidColorBrush x:Key="Panel" Color="{StaticResource PanelColor}" />
    <SolidColorBrush x:Key="Ink" Color="{StaticResource InkColor}" />
    <SolidColorBrush x:Key="Muted" Color="{StaticResource MutedColor}" />
    <SolidColorBrush x:Key="Line" Color="{StaticResource LineColor}" />
    <SolidColorBrush x:Key="Accent" Color="{StaticResource AccentColor}" />
    <SolidColorBrush x:Key="Accent2" Color="{StaticResource AccentColor2}" />
    <SolidColorBrush x:Key="AccentDarkBrush" Color="{StaticResource AccentDark}" />
    <SolidColorBrush x:Key="Danger" Color="{StaticResource DangerColor}" />
    <SolidColorBrush x:Key="Teal" Color="{StaticResource TealColor}" />
    <SolidColorBrush x:Key="Soft" Color="{StaticResource SoftColor}" />
    <SolidColorBrush x:Key="Head" Color="{StaticResource HeadColor}" />
  </Application.Resources>

  <Application.Styles>
    <FluentTheme />
    <StyleInclude Source="avares://AzadiTeb.Reception/Views/Styles.axaml" />
  </Application.Styles>
</Application>
