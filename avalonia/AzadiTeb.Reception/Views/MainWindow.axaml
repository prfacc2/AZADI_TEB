<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:AzadiTeb.Reception.ViewModels"
        x:Class="AzadiTeb.Reception.Views.MainWindow"
        x:DataType="vm:ReceptionViewModel"
        Title="پذیرش بیمار — آزادی طب"
        Width="1360" Height="860"
        MinWidth="980" MinHeight="640"
        WindowStartupLocation="CenterScreen"
        SystemDecorations="None"
        TransparencyLevelHint="None">

  <Grid RowDefinitions="Auto,*,Auto">

    <!-- ============ HEADER ============ -->
    <Border Grid.Row="0" Background="{StaticResource Panel}" BorderBrush="{StaticResource Line}"
            BorderThickness="0,0,0,1" Padding="16,10">
      <Grid ColumnDefinitions="Auto,*,Auto">
        <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
          <Border Background="{StaticResource Accent}" CornerRadius="9" Width="34" Height="34">
            <TextBlock Text="ط" Foreground="White" FontWeight="Bold" FontSize="18"
                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
          </Border>
          <StackPanel VerticalAlignment="Center">
            <TextBlock Text="پذیرش بیمار" FontWeight="Bold" FontSize="15"/>
            <TextBlock Text="{Binding StatusText}" FontSize="11" Foreground="{StaticResource Muted}"/>
          </StackPanel>
        </StackPanel>

        <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="14" VerticalAlignment="Center">
          <StackPanel Orientation="Horizontal" Spacing="6">
            <TextBlock Text="تاریخ:" Foreground="{StaticResource Muted}" FontSize="12" VerticalAlignment="Center"/>
            <TextBlock Text="{Binding HeaderDate}" FontWeight="Bold" FontSize="13" VerticalAlignment="Center"/>
          </StackPanel>
          <StackPanel Orientation="Horizontal" Spacing="6">
            <TextBlock Text="ساعت:" Foreground="{StaticResource Muted}" FontSize="12" VerticalAlignment="Center"/>
            <TextBlock Text="{Binding HeaderTime}" FontWeight="Bold" FontSize="13" VerticalAlignment="Center"/>
          </StackPanel>
        </StackPanel>
      </Grid>
    </Border>

    <!-- ============ BODY (3 columns) ============ -->
    <Grid Grid.Row="1" ColumnDefinitions="320,*,300" Margin="12">

      <!-- ===== RIGHT COLUMN (first in RTL) ===== -->
      <ScrollViewer Grid.Column="0" Margin="0,0,10,0" VerticalScrollBarVisibility="Auto">
        <StackPanel>

          <!-- Patient profile -->
          <Border Classes="card">
            <StackPanel Margin="12">
              <StackPanel Orientation="Horizontal" Spacing="10">
                <Border Background="{StaticResource Head}" CornerRadius="24" Width="46" Height="46">
                  <TextBlock Text="&#128100;" FontSize="22" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
                <StackPanel VerticalAlignment="Center">
                  <TextBlock Text="{Binding ProfileName}" FontWeight="Bold" FontSize="14"/>
                  <StackPanel Orientation="Horizontal" Spacing="4">
                    <TextBlock Text="کد پرونده:" FontSize="11" Foreground="{StaticResource Muted}"/>
                    <TextBlock Text="{Binding FileCode}" FontSize="11" FontWeight="Bold"/>
                  </StackPanel>
                </StackPanel>
              </StackPanel>

              <Button Classes="teal" Content="نسخه الکترونیک" HorizontalAlignment="Stretch"
                      Margin="0,10,0,0" Command="{Binding ElectronicRxCommand}"/>

              <Grid ColumnDefinitions="*,*" Margin="0,8,0,0">
                <Border Grid.Column="0" Background="{StaticResource Soft}" CornerRadius="8" Padding="8" Margin="0,0,4,0">
                  <StackPanel>
                    <TextBlock Text="نسخه (الکترونیکی)" FontSize="10" Foreground="{StaticResource Muted}"/>
                    <TextBlock Text="{Binding RxElectronic}" FontWeight="Bold" FontSize="15"/>
                  </StackPanel>
                </Border>
                <Border Grid.Column="1" Background="{StaticResource Soft}" CornerRadius="8" Padding="8" Margin="4,0,0,0">
                  <StackPanel>
                    <TextBlock Text="نسخه (سریالی)" FontSize="10" Foreground="{StaticResource Muted}"/>
                    <TextBlock Text="{Binding RxSerial}" FontWeight="Bold" FontSize="15"/>
                  </StackPanel>
                </Border>
              </Grid>

              <StackPanel Margin="0,8,0,0" Spacing="6">
                <StackPanel Orientation="Horizontal" Spacing="8">
                  <Border Background="{StaticResource Accent}" CornerRadius="6" Width="24" Height="24">
                    <TextBlock Text="P" Foreground="White" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                  </Border>
                  <TextBlock Text="پرداختی" VerticalAlignment="Center" Foreground="{StaticResource Muted}" FontSize="12"/>
                  <TextBlock Text="{Binding PsPaid}" VerticalAlignment="Center" FontWeight="Bold"/>
                  <TextBlock Text="نفر" VerticalAlignment="Center" Foreground="{StaticResource Muted}" FontSize="11"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" Spacing="8">
                  <Border Background="{StaticResource Teal}" CornerRadius="6" Width="24" Height="24">
                    <TextBlock Text="S" Foreground="White" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                  </Border>
                  <TextBlock Text="صندوق" VerticalAlignment="Center" Foreground="{StaticResource Muted}" FontSize="12"/>
                  <TextBlock Text="{Binding PsCash}" VerticalAlignment="Center" FontWeight="Bold"/>
                  <TextBlock Text="نفر" VerticalAlignment="Center" Foreground="{StaticResource Muted}" FontSize="11"/>
                </StackPanel>
              </StackPanel>
            </StackPanel>
          </Border>

          <!-- Search keys -->
          <Border Classes="card">
            <StackPanel>
              <Border Classes="card-head"><TextBlock Text="کلیدهای جستجو"/></Border>
              <StackPanel Margin="12" Spacing="8">
                <StackPanel>
                  <TextBlock Classes="fld-lbl" Text="شماره ملی / بارکد"/>
                  <Grid ColumnDefinitions="*,Auto">
                    <TextBox Grid.Column="0" Classes="inp" Text="{Binding QsNid}" Watermark="جستجو"/>
                    <Button Grid.Column="1" Classes="ghost" Content="&#128269;" Margin="6,0,0,0"
                            Command="{Binding LookupNidCommand}"/>
                  </Grid>
                </StackPanel>
                <StackPanel>
                  <TextBlock Classes="fld-lbl" Text="شماره پرونده / نام"/>
                  <Grid ColumnDefinitions="*,Auto">
                    <TextBox Grid.Column="0" Classes="inp" Text="{Binding QsFile}" Watermark="جستجو"/>
                    <Button Grid.Column="1" Classes="ghost" Content="&#128269;" Margin="6,0,0,0"
                            Command="{Binding SearchPatientCommand}"/>
                  </Grid>
                </StackPanel>
                <Border Background="{StaticResource Soft}" CornerRadius="8" MaxHeight="180"
                        IsVisible="{Binding PatientResults.Count}">
                  <ScrollViewer>
                    <ItemsControl ItemsSource="{Binding PatientResults}">
                      <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="vm:SuggestRow">
                          <Button Classes="ghost" HorizontalAlignment="Stretch" Margin="4,2" Padding="8,5"
                                  Command="{Binding $parent[ItemsControl].((vm:ReceptionViewModel)DataContext).PickPatientCommand}"
                                  CommandParameter="{Binding}">
                            <StackPanel HorizontalAlignment="Stretch">
                              <TextBlock Text="{Binding Primary}" FontWeight="Bold" FontSize="12"/>
                              <TextBlock Text="{Binding Secondary}" FontSize="11" Foreground="{StaticResource Muted}"/>
                            </StackPanel>
                          </Button>
                        </DataTemplate>
                      </ItemsControl.ItemTemplate>
                    </ItemsControl>
                  </ScrollViewer>
                </Border>
              </StackPanel>
            </StackPanel>
          </Border>

          <!-- Insurance -->
          <Border Classes="card">
            <StackPanel>
              <Border Classes="card-head">
                <Grid ColumnDefinitions="*,Auto">
                  <TextBlock Grid.Column="0" Text="بیمه"/>
                  <CheckBox Grid.Column="1" Content="فعال" IsChecked="{Binding HasInsurance}" FontSize="12"/>
                </Grid>
              </Border>
              <StackPanel Margin="12" Spacing="8">
                <StackPanel>
                  <TextBlock Classes="fld-lbl" Text="شماره دفترچه"/>
                  <TextBox Classes="inp" Text="{Binding InsBooklet}"/>
                </StackPanel>
                <StackPanel>
                  <TextBlock Classes="fld-lbl" Text="بیمه پایه"/>
                  <ComboBox Classes="inp" ItemsSource="{Binding InsuranceMain}" SelectedIndex="{Binding InsMainIndex}"/>
                </StackPanel>
                <Grid ColumnDefinitions="*,*">
                  <StackPanel Grid.Column="0" Margin="0,0,4,0">
                    <TextBlock Classes="fld-lbl" Text="تاریخ اعتبار"/>
                    <TextBox Classes="inp" Text="{Binding InsValid}" Watermark="۱۴۰۵/۰۶/۱۵"/>
                  </StackPanel>
                  <StackPanel Grid.Column="1" Margin="4,0,0,0">
                    <TextBlock Classes="fld-lbl" Text="تاریخ نسخه"/>
                    <TextBox Classes="inp" Text="{Binding RxDate}" Watermark="۱۴۰۵/۰۶/۱۵"/>
                  </StackPanel>
                </Grid>
                <StackPanel>
                  <TextBlock Classes="fld-lbl" Text="بیمه مکمل"/>
                  <ComboBox Classes="inp" ItemsSource="{Binding InsuranceSupp}" SelectedIndex="{Binding InsSuppIndex}"/>
                </StackPanel>
                <StackPanel>
                  <TextBlock Classes="fld-lbl" Text="درصد بیمه تکمیلی"/>
                  <TextBox Classes="inp" Text="{Binding InsSuppPct}"/>
                </StackPanel>
              </StackPanel>
            </StackPanel>
          </Border>

          <!-- Doctor search -->
          <Border Classes="card">
            <StackPanel>
              <Border Classes="card-head"><TextBlock Text="جستجوی پزشک معالج"/></Border>
              <StackPanel Margin="12" Spacing="8">
                <StackPanel>
                  <TextBlock Classes="fld-lbl" Text="شماره نظام پزشکی"/>
                  <Grid ColumnDefinitions="*,Auto">
                    <TextBox Grid.Column="0" Classes="inp" Text="{Binding DocCode}"/>
                    <Button Grid.Column="1" Classes="ghost" Content="&#128269;" Margin="6,0,0,0"
                            Command="{Binding SearchDoctorCommand}"/>
                  </Grid>
                </StackPanel>
                <StackPanel>
                  <TextBlock Classes="fld-lbl" Text="نام پزشک"/>
                  <Grid ColumnDefinitions="*,Auto">
                    <TextBox Grid.Column="0" Classes="inp" Text="{Binding DocSearch}" Watermark="نام پزشک یا کد…"/>
                    <Button Grid.Column="1" Classes="ghost" Content="&#128269;" Margin="6,0,0,0"
                            Command="{Binding SearchDoctorCommand}"/>
                  </Grid>
                </StackPanel>
                <Border Background="{StaticResource Soft}" CornerRadius="8" MaxHeight="160"
                        IsVisible="{Binding DoctorResults.Count}">
                  <ScrollViewer>
                    <ItemsControl ItemsSource="{Binding DoctorResults}">
                      <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="vm:SuggestRow">
                          <Button Classes="ghost" HorizontalAlignment="Stretch" Margin="4,2" Padding="8,5"
                                  Command="{Binding $parent[ItemsControl].((vm:ReceptionViewModel)DataContext).PickDoctorCommand}"
                                  CommandParameter="{Binding}">
                            <StackPanel HorizontalAlignment="Stretch">
                              <TextBlock Text="{Binding Primary}" FontWeight="Bold" FontSize="12"/>
                              <TextBlock Text="{Binding Secondary}" FontSize="11" Foreground="{StaticResource Muted}"/>
                            </StackPanel>
                          </Button>
                        </DataTemplate>
                      </ItemsControl.ItemTemplate>
                    </ItemsControl>
                  </ScrollViewer>
                </Border>
              </StackPanel>
            </StackPanel>
          </Border>

        </StackPanel>
      </ScrollViewer>

      <!-- ===== CENTER COLUMN ===== -->
      <ScrollViewer Grid.Column="1" Margin="0,0,10,0" VerticalScrollBarVisibility="Auto">
        <StackPanel>

          <!-- Patient info grid -->
          <Border Classes="card">
            <StackPanel>
              <Border Classes="card-head"><TextBlock Text="مشخصات بیمار"/></Border>
              <Grid Margin="12" ColumnDefinitions="*,*,*,*" RowDefinitions="Auto,Auto,Auto">
                <StackPanel Grid.Row="0" Grid.Column="3" Margin="4">
                  <TextBlock Classes="fld-lbl" Text="نام"/>
                  <TextBox Classes="inp" Text="{Binding First}"/>
                </StackPanel>
                <StackPanel Grid.Row="0" Grid.Column="2" Margin="4">
                  <TextBlock Classes="fld-lbl" Text="نام خانوادگی"/>
                  <TextBox Classes="inp" Text="{Binding Last}"/>
                </StackPanel>
                <StackPanel Grid.Row="0" Grid.Column="1" Margin="4">
                  <TextBlock Classes="fld-lbl" Text="کد ملی"/>
                  <TextBox Classes="inp" Text="{Binding Nid}" Watermark="۱۰ رقم — Enter استعلام"/>
                </StackPanel>
                <StackPanel Grid.Row="0" Grid.Column="0" Margin="4">
                  <TextBlock Classes="fld-lbl" Text="نام پدر"/>
                  <TextBox Classes="inp" Text="{Binding Father}"/>
                </StackPanel>

                <StackPanel Grid.Row="1" Grid.Column="3" Margin="4">
                  <TextBlock Classes="fld-lbl" Text="تاریخ تولد"/>
                  <TextBox Classes="inp" Text="{Binding Birth}" Watermark="۱۴۰۰/۰۳/۲۳"/>
                </StackPanel>
                <StackPanel Grid.Row="1" Grid.Column="2" Margin="4">
                  <TextBlock Classes="fld-lbl" Text="جنسیت"/>
                  <ComboBox Classes="inp" ItemsSource="{Binding Genders}" SelectedIndex="{Binding GenderIndex}"/>
                </StackPanel>
                <StackPanel Grid.Row="1" Grid.Column="1" Margin="4">
                  <TextBlock Classes="fld-lbl" Text="شماره موبایل"/>
                  <TextBox Classes="inp" Text="{Binding Mobile}"/>
                </StackPanel>
                <StackPanel Grid.Row="1" Grid.Column="0" Margin="4">
                  <TextBlock Classes="fld-lbl" Text="تلفن ثابت"/>
                  <TextBox Classes="inp" Text="{Binding Phone}"/>
                </StackPanel>

                <StackPanel Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="4" Margin="4">
                  <TextBlock Classes="fld-lbl" Text="آدرس"/>
                  <TextBox Classes="inp" Text="{Binding Addr}"/>
                </StackPanel>
              </Grid>
            </StackPanel>
          </Border>

          <!-- Visit / insurance-type + doctor cards -->
          <Grid ColumnDefinitions="*,*,*">
            <Border Grid.Column="2" Classes="card" Margin="0,0,5,10">
              <StackPanel>
                <Border Classes="card-head"><TextBlock Text="پذیرش و نوبت"/></Border>
                <StackPanel Margin="10" Spacing="7">
                  <StackPanel>
                    <TextBlock Classes="fld-lbl" Text="نوع پذیرش"/>
                    <ComboBox Classes="inp" ItemsSource="{Binding PatientTypes}" SelectedIndex="{Binding PTypeIndex}"/>
                  </StackPanel>
                  <StackPanel>
                    <TextBlock Classes="fld-lbl" Text="نوع نوبت"/>
                    <ComboBox Classes="inp" ItemsSource="{Binding VisitTypes}" SelectedIndex="{Binding NTypeIndex}"/>
                  </StackPanel>
                  <StackPanel>
                    <TextBlock Classes="fld-lbl" Text="شیفت نوبت"/>
                    <ComboBox Classes="inp" ItemsSource="{Binding Shifts}" SelectedIndex="{Binding ShiftIndex}"/>
                  </StackPanel>
                  <StackPanel>
                    <TextBlock Classes="fld-lbl" Text="تاریخ نوبت"/>
                    <TextBox Classes="inp" Text="{Binding ApptDate}" Watermark="۱۴۰۵/۰۶/۱۵"/>
                  </StackPanel>
                </StackPanel>
              </StackPanel>
            </Border>

            <Border Grid.Column="1" Classes="card" Margin="5,0,5,10">
              <StackPanel>
                <Border Classes="card-head"><TextBlock Text="پزشک معالج"/></Border>
                <StackPanel Margin="10" Spacing="7">
                  <StackPanel>
                    <TextBlock Classes="fld-lbl" Text="شماره نظام پزشکی"/>
                    <TextBox Classes="inp" Text="{Binding Doc2Code}"/>
                  </StackPanel>
                  <StackPanel>
                    <TextBlock Classes="fld-lbl" Text="نام پزشک"/>
                    <ComboBox Classes="inp" ItemsSource="{Binding Doctors}" SelectedIndex="{Binding Doc2Index}"/>
                  </StackPanel>
                </StackPanel>
              </StackPanel>
            </Border>

            <Border Grid.Column="0" Classes="card" Margin="5,0,0,10">
              <StackPanel>
                <Border Classes="card-head"><TextBlock Text="انجام دهنده"/></Border>
                <StackPanel Margin="10" Spacing="7">
                  <StackPanel>
                    <TextBlock Classes="fld-lbl" Text="کد انجام دهنده"/>
                    <TextBox Classes="inp" Text="{Binding PerfCode}"/>
                  </StackPanel>
                  <StackPanel>
                    <TextBlock Classes="fld-lbl" Text="نام انجام دهنده"/>
                    <ComboBox Classes="inp" ItemsSource="{Binding Doctors}" SelectedIndex="{Binding PerfIndex}"/>
                  </StackPanel>
                </StackPanel>
              </StackPanel>
            </Border>
          </Grid>

          <!-- Services -->
          <Border Classes="card">
            <StackPanel>
              <Border Classes="card-head">
                <Grid ColumnDefinitions="Auto,*,Auto">
                  <TextBlock Grid.Column="0" Text="خدمات" VerticalAlignment="Center"/>
                  <TextBox Grid.Column="1" Classes="inp" Text="{Binding SvcSearch}" Margin="10,0"
                           Watermark="جستجوی خدمت (کد یا نام)…" MinHeight="30"/>
                  <Button Grid.Column="2" Classes="primary" Content="افزودن خدمت" Padding="12,6"
                          Command="{Binding AddServiceCommand}"/>
                </Grid>
              </Border>

              <Border Background="{StaticResource Soft}" CornerRadius="8" Margin="10,10,10,0" MaxHeight="160"
                      IsVisible="{Binding ServiceSuggest.Count}">
                <ScrollViewer>
                  <ItemsControl ItemsSource="{Binding ServiceSuggest}">
                    <ItemsControl.ItemTemplate>
                      <DataTemplate x:DataType="vm:SuggestRow">
                        <Button Classes="ghost" HorizontalAlignment="Stretch" Margin="4,2" Padding="8,5"
                                Command="{Binding $parent[ItemsControl].((vm:ReceptionViewModel)DataContext).PickServiceCommand}"
                                CommandParameter="{Binding}">
                          <Grid ColumnDefinitions="*,Auto" HorizontalAlignment="Stretch">
                            <StackPanel Grid.Column="0">
                              <TextBlock Text="{Binding Primary}" FontWeight="Bold" FontSize="12"/>
                              <TextBlock Text="{Binding Secondary}" FontSize="11" Foreground="{StaticResource Muted}"/>
                            </StackPanel>
                            <TextBlock Grid.Column="1" Text="{Binding PriceDisplay}" VerticalAlignment="Center"
                                       FontSize="12" Foreground="{StaticResource Accent}"/>
                          </Grid>
                        </Button>
                      </DataTemplate>
                    </ItemsControl.ItemTemplate>
                  </ItemsControl>
                </ScrollViewer>
              </Border>

              <!-- services table header -->
              <Border Classes="thead" Margin="10,10,10,0" CornerRadius="8,8,0,0">
                <Grid ColumnDefinitions="40,*,80,50,110,90,110,110,44">
                  <TextBlock Grid.Column="0" Text="#"/>
                  <TextBlock Grid.Column="1" Text="نام خدمت"/>
                  <TextBlock Grid.Column="2" Text="کد"/>
                  <TextBlock Grid.Column="3" Text="تعداد"/>
                  <TextBlock Grid.Column="4" Text="مبلغ"/>
                  <TextBlock Grid.Column="5" Text="تخفیف"/>
                  <TextBlock Grid.Column="6" Text="سهم بیمه"/>
                  <TextBlock Grid.Column="7" Text="سهم بیمار"/>
                  <TextBlock Grid.Column="8" Text=""/>
                </Grid>
              </Border>
              <Border BorderBrush="{StaticResource Line}" BorderThickness="1,0,1,1" Margin="10,0,10,0"
                      CornerRadius="0,0,8,8">
                <ItemsControl ItemsSource="{Binding Services}" MinHeight="60">
                  <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="vm:ServiceRow">
                      <Border BorderBrush="{StaticResource Line}" BorderThickness="0,0,0,1" Padding="0,3">
                        <Grid ColumnDefinitions="40,*,80,50,110,90,110,110,44">
                          <TextBlock Grid.Column="0" Text="{Binding RowIndexDisplay}" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="12"/>
                          <TextBlock Grid.Column="1" Text="{Binding Name}" VerticalAlignment="Center" FontSize="12" Margin="4,0"/>
                          <TextBlock Grid.Column="2" Text="{Binding Code}" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="12"/>
                          <TextBlock Grid.Column="3" Text="{Binding QtyDisplay}" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="12"/>
                          <TextBlock Grid.Column="4" Text="{Binding PriceDisplay}" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="12"/>
                          <TextBlock Grid.Column="5" Text="{Binding DiscountDisplay}" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="12"/>
                          <TextBlock Grid.Column="6" Text="{Binding InsShareDisplay}" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="12"/>
                          <TextBlock Grid.Column="7" Text="{Binding PatientShareDisplay}" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="12"/>
                          <Button Grid.Column="8" Classes="danger" Content="&#10005;" Padding="6,3" VerticalAlignment="Center"
                                  Command="{Binding $parent[ItemsControl].((vm:ReceptionViewModel)DataContext).RemoveServiceCommand}"
                                  CommandParameter="{Binding}"/>
                        </Grid>
                      </Border>
                    </DataTemplate>
                  </ItemsControl.ItemTemplate>
                </ItemsControl>
              </Border>

              <!-- services footer sums -->
              <Grid Margin="10" ColumnDefinitions="*,*,*,*">
                <Border Grid.Column="3" Background="{StaticResource Soft}" CornerRadius="8" Padding="8" Margin="0,0,4,0">
                  <StackPanel>
                    <TextBlock Classes="sumKey" Text="جمع خدمات"/>
                    <TextBlock Classes="sumVal" Text="{Binding SumGross}"/>
                  </StackPanel>
                </Border>
                <Border Grid.Column="2" Background="{StaticResource Soft}" CornerRadius="8" Padding="8" Margin="4,0">
                  <StackPanel>
                    <TextBlock Classes="sumKey" Text="جمع تخفیف"/>
                    <TextBlock Classes="sumVal" Text="{Binding SumDiscount}"/>
                  </StackPanel>
                </Border>
                <Border Grid.Column="1" Background="{StaticResource Soft}" CornerRadius="8" Padding="8" Margin="4,0">
                  <StackPanel>
                    <TextBlock Classes="sumKey" Text="جمع سهم بیمه"/>
                    <TextBlock Classes="sumVal" Text="{Binding SumInsShare}"/>
                  </StackPanel>
                </Border>
                <Border Grid.Column="0" Background="{StaticResource Soft}" CornerRadius="8" Padding="8" Margin="4,0,0,0">
                  <StackPanel>
                    <TextBlock Classes="sumKey" Text="جمع سهم بیمار"/>
                    <TextBlock Classes="sumVal" Text="{Binding SumPatShare}"/>
                  </StackPanel>
                </Border>
              </Grid>
            </StackPanel>
          </Border>

          <!-- Unpaid queue -->
          <Border Classes="card">
            <StackPanel>
              <Border Classes="card-head">
                <Grid ColumnDefinitions="Auto,*,Auto">
                  <TextBlock Grid.Column="0" Text="صندوق نرفته‌ها" VerticalAlignment="Center"/>
                  <TextBox Grid.Column="1" Classes="inp" Text="{Binding QSearch}" Margin="10,0" MinHeight="30"
                           Watermark="جستجو بر اساس نام، کد ملی…"/>
                  <Button Grid.Column="2" Classes="ghost" Content="افزودن به صف" Padding="10,6"
                          Command="{Binding AddToQueueCommand}"/>
                </Grid>
              </Border>
              <Border Classes="thead" Margin="10,10,10,0" CornerRadius="8,8,0,0">
                <Grid ColumnDefinitions="40,*,140,90,80,80,110,44">
                  <TextBlock Grid.Column="0" Text="#"/>
                  <TextBlock Grid.Column="1" Text="نام بیمار"/>
                  <TextBlock Grid.Column="2" Text="بارکد / کد پرونده"/>
                  <TextBlock Grid.Column="3" Text="تاریخ"/>
                  <TextBlock Grid.Column="4" Text="زمان"/>
                  <TextBlock Grid.Column="5" Text="دقیقه پیش"/>
                  <TextBlock Grid.Column="6" Text="مبلغ"/>
                  <TextBlock Grid.Column="7" Text=""/>
                </Grid>
              </Border>
              <Border BorderBrush="{StaticResource Line}" BorderThickness="1,0,1,1" Margin="10,0,10,0"
                      CornerRadius="0,0,8,8">
                <ItemsControl ItemsSource="{Binding Queue}" MinHeight="50">
                  <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="vm:QueueRow">
                      <Border BorderBrush="{StaticResource Line}" BorderThickness="0,0,0,1" Padding="0,4">
                        <Grid ColumnDefinitions="40,*,140,90,80,80,110,44">
                          <TextBlock Grid.Column="0" Text="{Binding RowIndexDisplay}" HorizontalAlignment="Center" FontSize="12"/>
                          <TextBlock Grid.Column="1" Text="{Binding PatientName}" FontSize="12" Margin="4,0"/>
                          <TextBlock Grid.Column="2" Text="{Binding Barcode}" HorizontalAlignment="Center" FontSize="12"/>
                          <TextBlock Grid.Column="3" Text="{Binding JDateDisplay}" HorizontalAlignment="Center" FontSize="12"/>
                          <TextBlock Grid.Column="4" Text="{Binding TimeDisplay}" HorizontalAlignment="Center" FontSize="12"/>
                          <TextBlock Grid.Column="5" Text="{Binding MinutesAgoDisplay}" HorizontalAlignment="Center" FontSize="12"/>
                          <TextBlock Grid.Column="6" Text="{Binding AmountDisplay}" HorizontalAlignment="Center" FontSize="12"/>
                          <Button Grid.Column="7" Classes="danger" Content="&#10005;" Padding="6,3"
                                  Command="{Binding $parent[ItemsControl].((vm:ReceptionViewModel)DataContext).RemoveQueueCommand}"
                                  CommandParameter="{Binding}"/>
                        </Grid>
                      </Border>
                    </DataTemplate>
                  </ItemsControl.ItemTemplate>
                </ItemsControl>
              </Border>
              <StackPanel Orientation="Horizontal" Margin="12,8" Spacing="6">
                <TextBlock Text="تعداد کل:" Foreground="{StaticResource Muted}" FontSize="12"/>
                <TextBlock Text="{Binding QueueCount}" FontWeight="Bold" FontSize="12"/>
              </StackPanel>
            </StackPanel>
          </Border>

        </StackPanel>
      </ScrollViewer>

      <!-- ===== LEFT COLUMN (invoice + actions) ===== -->
      <ScrollViewer Grid.Column="2" VerticalScrollBarVisibility="Auto">
        <StackPanel>
          <!-- primary actions -->
          <Border Classes="card">
            <StackPanel Margin="12" Spacing="8">
              <CheckBox Content="عدم پرداخت فعلی" IsChecked="{Binding NoPay}" FontSize="12"/>
              <Button Classes="primary" Content="ثبت پذیرش و صدور قبض" HorizontalAlignment="Stretch"
                      Command="{Binding SaveCommand}"/>
              <Button Classes="ghost" Content="پذیرش جدید" HorizontalAlignment="Stretch"
                      Command="{Binding NewAdmissionCommand}"/>
              <Button Classes="ghost" Content="چاپ آخرین قبض" HorizontalAlignment="Stretch"
                      Command="{Binding PrintLastCommand}"/>
            </StackPanel>
          </Border>

          <!-- invoice summary -->
          <Border Classes="card">
            <StackPanel>
              <Border Classes="card-head"><TextBlock Text="صورتحساب"/></Border>
              <StackPanel Margin="12" Spacing="10">
                <Grid ColumnDefinitions="*,Auto">
                  <TextBlock Grid.Column="0" Classes="sumKey" Text="جمع کل"/>
                  <TextBlock Grid.Column="1" Classes="sumVal" Text="{Binding InvTotal}"/>
                </Grid>
                <Grid ColumnDefinitions="*,Auto">
                  <TextBlock Grid.Column="0" Classes="sumKey" Text="سهم سازمان"/>
                  <TextBlock Grid.Column="1" Classes="sumVal" Text="{Binding InvOrg}"/>
                </Grid>
                <Grid ColumnDefinitions="*,Auto">
                  <TextBlock Grid.Column="0" Classes="sumKey" Text="سهم بیمار"/>
                  <TextBlock Grid.Column="1" Classes="sumVal" Text="{Binding InvPatient}"/>
                </Grid>
                <Border Background="{StaticResource Line}" Height="1"/>
                <Grid ColumnDefinitions="*,Auto">
                  <TextBlock Grid.Column="0" Text="مبلغ نهایی" FontWeight="Bold" FontSize="14"/>
                  <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="4">
                    <TextBlock Text="{Binding InvFinal}" FontWeight="Bold" FontSize="16" Foreground="{StaticResource Accent}"/>
                    <TextBlock Text="ریال" FontSize="11" Foreground="{StaticResource Muted}" VerticalAlignment="Bottom"/>
                  </StackPanel>
                </Grid>
              </StackPanel>
            </StackPanel>
          </Border>
        </StackPanel>
      </ScrollViewer>

    </Grid>

    <!-- ============ FOOTER ============ -->
    <Border Grid.Row="2" Background="{StaticResource Panel}" BorderBrush="{StaticResource Line}"
            BorderThickness="0,1,0,0" Padding="16,6">
      <TextBlock Text="{Binding StatusText}" FontSize="11" Foreground="{StaticResource Muted}"/>
    </Border>

    <!-- Loader overlay -->
    <Border Grid.Row="0" Grid.RowSpan="3" Background="#f4f8fe" IsVisible="{Binding Busy}">
      <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="12">
        <TextBlock Text="در حال بارگذاری پذیرش بیمار…" FontSize="15" Foreground="{StaticResource Accent}"/>
      </StackPanel>
    </Border>

  </Grid>
</Window>
