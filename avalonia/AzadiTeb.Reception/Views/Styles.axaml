<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

  <!-- Global: Vazirmatn font + RTL everywhere, matching the HTML surface. -->
  <Style Selector="Window">
    <Setter Property="FontFamily" Value="{StaticResource Vazir}" />
    <Setter Property="FlowDirection" Value="RightToLeft" />
    <Setter Property="Background" Value="{StaticResource Bg}" />
  </Style>

  <Style Selector="TextBlock">
    <Setter Property="FontFamily" Value="{StaticResource Vazir}" />
    <Setter Property="Foreground" Value="{StaticResource Ink}" />
  </Style>

  <!-- Card container (.card) -->
  <Style Selector="Border.card">
    <Setter Property="Background" Value="{StaticResource Panel}" />
    <Setter Property="BorderBrush" Value="{StaticResource Line}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="12" />
    <Setter Property="Padding" Value="0" />
    <Setter Property="Margin" Value="0,0,0,10" />
  </Style>

  <!-- Card head (.card-head) -->
  <Style Selector="Border.card-head">
    <Setter Property="Background" Value="{StaticResource Head}" />
    <Setter Property="CornerRadius" Value="12,12,0,0" />
    <Setter Property="Padding" Value="12,9" />
    <Setter Property="BorderBrush" Value="{StaticResource Line}" />
    <Setter Property="BorderThickness" Value="0,0,0,1" />
  </Style>
  <Style Selector="Border.card-head > TextBlock">
    <Setter Property="FontWeight" Value="Bold" />
    <Setter Property="FontSize" Value="13" />
    <Setter Property="Foreground" Value="{StaticResource InkColor}" />
  </Style>

  <!-- Field label (.fld) -->
  <Style Selector="TextBlock.fld-lbl">
    <Setter Property="FontSize" Value="12" />
    <Setter Property="Foreground" Value="{StaticResource Muted}" />
    <Setter Property="Margin" Value="2,0,2,3" />
  </Style>

  <!-- Inputs (.inp) -->
  <Style Selector="TextBox.inp">
    <Setter Property="FontFamily" Value="{StaticResource Vazir}" />
    <Setter Property="CornerRadius" Value="9" />
    <Setter Property="MinHeight" Value="36" />
    <Setter Property="Padding" Value="10,6" />
    <Setter Property="BorderBrush" Value="{StaticResource Line}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="Background" Value="{StaticResource Soft}" />
    <Setter Property="FontSize" Value="13" />
    <Setter Property="HorizontalContentAlignment" Value="Right" />
  </Style>
  <Style Selector="TextBox.inp:focus">
    <Setter Property="BorderBrush" Value="{StaticResource Accent}" />
    <Setter Property="Background" Value="{StaticResource Panel}" />
  </Style>

  <Style Selector="ComboBox.inp">
    <Setter Property="FontFamily" Value="{StaticResource Vazir}" />
    <Setter Property="CornerRadius" Value="9" />
    <Setter Property="MinHeight" Value="36" />
    <Setter Property="Padding" Value="10,4" />
    <Setter Property="BorderBrush" Value="{StaticResource Line}" />
    <Setter Property="Background" Value="{StaticResource Soft}" />
    <Setter Property="FontSize" Value="13" />
    <Setter Property="HorizontalAlignment" Value="Stretch" />
  </Style>

  <!-- Primary button (.btn-submit / .btn-primary) -->
  <Style Selector="Button.primary">
    <Setter Property="Background" Value="{StaticResource Accent}" />
    <Setter Property="Foreground" Value="White" />
    <Setter Property="FontFamily" Value="{StaticResource Vazir}" />
    <Setter Property="FontWeight" Value="Bold" />
    <Setter Property="CornerRadius" Value="10" />
    <Setter Property="Padding" Value="14,9" />
    <Setter Property="FontSize" Value="13" />
    <Setter Property="HorizontalContentAlignment" Value="Center" />
    <Setter Property="Cursor" Value="Hand" />
  </Style>
  <Style Selector="Button.primary:pointerover /template/ ContentPresenter">
    <Setter Property="Background" Value="{StaticResource AccentDarkBrush}" />
  </Style>

  <Style Selector="Button.teal">
    <Setter Property="Background" Value="{StaticResource Teal}" />
    <Setter Property="Foreground" Value="White" />
    <Setter Property="FontFamily" Value="{StaticResource Vazir}" />
    <Setter Property="FontWeight" Value="Bold" />
    <Setter Property="CornerRadius" Value="10" />
    <Setter Property="Padding" Value="12,9" />
    <Setter Property="FontSize" Value="13" />
    <Setter Property="HorizontalContentAlignment" Value="Center" />
    <Setter Property="Cursor" Value="Hand" />
  </Style>

  <Style Selector="Button.ghost">
    <Setter Property="Background" Value="{StaticResource Panel}" />
    <Setter Property="Foreground" Value="{StaticResource Ink}" />
    <Setter Property="FontFamily" Value="{StaticResource Vazir}" />
    <Setter Property="CornerRadius" Value="9" />
    <Setter Property="Padding" Value="10,6" />
    <Setter Property="BorderBrush" Value="{StaticResource Line}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="FontSize" Value="13" />
    <Setter Property="Cursor" Value="Hand" />
  </Style>

  <Style Selector="Button.danger">
    <Setter Property="Background" Value="{StaticResource Danger}" />
    <Setter Property="Foreground" Value="White" />
    <Setter Property="FontFamily" Value="{StaticResource Vazir}" />
    <Setter Property="FontWeight" Value="Bold" />
    <Setter Property="CornerRadius" Value="9" />
    <Setter Property="Padding" Value="8,5" />
    <Setter Property="FontSize" Value="12" />
    <Setter Property="Cursor" Value="Hand" />
  </Style>

  <!-- Invoice / footer sum cells -->
  <Style Selector="TextBlock.sumKey">
    <Setter Property="Foreground" Value="{StaticResource Muted}" />
    <Setter Property="FontSize" Value="12" />
  </Style>
  <Style Selector="TextBlock.sumVal">
    <Setter Property="Foreground" Value="{StaticResource InkColor}" />
    <Setter Property="FontWeight" Value="Bold" />
    <Setter Property="FontSize" Value="13" />
  </Style>

  <!-- Data grid-ish table header -->
  <Style Selector="Border.thead">
    <Setter Property="Background" Value="{StaticResource Head}" />
    <Setter Property="BorderBrush" Value="{StaticResource Line}" />
    <Setter Property="BorderThickness" Value="0,0,0,1" />
    <Setter Property="Padding" Value="6,7" />
  </Style>
  <Style Selector="Border.thead TextBlock">
    <Setter Property="FontWeight" Value="Bold" />
    <Setter Property="FontSize" Value="12" />
    <Setter Property="HorizontalAlignment" Value="Center" />
    <Setter Property="Foreground" Value="{StaticResource InkColor}" />
  </Style>

</Styles>
