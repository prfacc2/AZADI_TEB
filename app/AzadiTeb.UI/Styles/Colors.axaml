<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <!-- ============================================================
         Azadi-Teb design tokens — ported from the print-designer
         HTML palette the operators liked (calm, modern, RTL).
         Light + Dark variants via ThemeDictionaries.
         ============================================================ -->
    <ResourceDictionary.ThemeDictionaries>

        <!-- ===================== LIGHT ===================== -->
        <ResourceDictionary x:Key="Light">
            <Color x:Key="AppBgColor">#EEF1F6</Color>
            <Color x:Key="AppBgColor2">#E4E9F2</Color>
            <Color x:Key="PanelColor">#FFFFFF</Color>
            <Color x:Key="PanelAltColor">#F7F9FD</Color>
            <Color x:Key="InkColor">#1D2433</Color>
            <Color x:Key="MutedColor">#6B7488</Color>
            <Color x:Key="LineColor">#DDE3EC</Color>
            <Color x:Key="LineStrongColor">#C4CEDE</Color>
            <Color x:Key="AccentColor">#1F6FEB</Color>
            <Color x:Key="AccentDarkColor">#1759C4</Color>
            <Color x:Key="AccentSoftColor">#E8F0FF</Color>
            <Color x:Key="TealColor">#0EA5A4</Color>
            <Color x:Key="TealDarkColor">#0F766E</Color>
            <Color x:Key="FieldSoftColor">#EAF1FF</Color>
            <Color x:Key="DangerColor">#E5484D</Color>
            <Color x:Key="DangerSoftColor">#FDECED</Color>
            <Color x:Key="OkColor">#16A34A</Color>
            <Color x:Key="OkSoftColor">#E7F6EC</Color>
            <Color x:Key="WarnColor">#D97706</Color>
            <Color x:Key="HeaderGrad1">#FFFFFF</Color>
            <Color x:Key="HeaderGrad2">#F3F6FB</Color>
            <Color x:Key="ShadowColor">#1A142860</Color>
        </ResourceDictionary>

        <!-- ===================== DARK ===================== -->
        <ResourceDictionary x:Key="Dark">
            <Color x:Key="AppBgColor">#0F1420</Color>
            <Color x:Key="AppBgColor2">#141B2B</Color>
            <Color x:Key="PanelColor">#1A2233</Color>
            <Color x:Key="PanelAltColor">#212B40</Color>
            <Color x:Key="InkColor">#E7ECF5</Color>
            <Color x:Key="MutedColor">#9AA6BD</Color>
            <Color x:Key="LineColor">#2C3852</Color>
            <Color x:Key="LineStrongColor">#3A496A</Color>
            <Color x:Key="AccentColor">#4C8DFF</Color>
            <Color x:Key="AccentDarkColor">#3B78E0</Color>
            <Color x:Key="AccentSoftColor">#1E2E4D</Color>
            <Color x:Key="TealColor">#22C2BE</Color>
            <Color x:Key="TealDarkColor">#0F766E</Color>
            <Color x:Key="FieldSoftColor">#1C2A44</Color>
            <Color x:Key="DangerColor">#FF6B6F</Color>
            <Color x:Key="DangerSoftColor">#3A1F22</Color>
            <Color x:Key="OkColor">#34D07E</Color>
            <Color x:Key="OkSoftColor">#16321F</Color>
            <Color x:Key="WarnColor">#F5A623</Color>
            <Color x:Key="HeaderGrad1">#1E2740</Color>
            <Color x:Key="HeaderGrad2">#161E30</Color>
            <Color x:Key="ShadowColor">#00000090</Color>
        </ResourceDictionary>
    </ResourceDictionary.ThemeDictionaries>

    <!-- ===================== Brushes (resolve to theme colors) ===================== -->
    <SolidColorBrush x:Key="AppBgBrush" Color="{DynamicResource AppBgColor}" />
    <SolidColorBrush x:Key="PanelBrush" Color="{DynamicResource PanelColor}" />
    <SolidColorBrush x:Key="PanelAltBrush" Color="{DynamicResource PanelAltColor}" />
    <SolidColorBrush x:Key="InkBrush" Color="{DynamicResource InkColor}" />
    <SolidColorBrush x:Key="MutedBrush" Color="{DynamicResource MutedColor}" />
    <SolidColorBrush x:Key="LineBrush" Color="{DynamicResource LineColor}" />
    <SolidColorBrush x:Key="LineStrongBrush" Color="{DynamicResource LineStrongColor}" />
    <SolidColorBrush x:Key="AccentBrush" Color="{DynamicResource AccentColor}" />
    <SolidColorBrush x:Key="AccentDarkBrush" Color="{DynamicResource AccentDarkColor}" />
    <SolidColorBrush x:Key="AccentSoftBrush" Color="{DynamicResource AccentSoftColor}" />
    <SolidColorBrush x:Key="TealBrush" Color="{DynamicResource TealColor}" />
    <SolidColorBrush x:Key="TealDarkBrush" Color="{DynamicResource TealDarkColor}" />
    <SolidColorBrush x:Key="FieldSoftBrush" Color="{DynamicResource FieldSoftColor}" />
    <SolidColorBrush x:Key="DangerBrush" Color="{DynamicResource DangerColor}" />
    <SolidColorBrush x:Key="DangerSoftBrush" Color="{DynamicResource DangerSoftColor}" />
    <SolidColorBrush x:Key="OkBrush" Color="{DynamicResource OkColor}" />
    <SolidColorBrush x:Key="OkSoftBrush" Color="{DynamicResource OkSoftColor}" />
    <SolidColorBrush x:Key="WarnBrush" Color="{DynamicResource WarnColor}" />

    <LinearGradientBrush x:Key="AppBgGradient" StartPoint="0%,0%" EndPoint="0%,100%">
        <GradientStop Offset="0" Color="{DynamicResource AppBgColor}" />
        <GradientStop Offset="1" Color="{DynamicResource AppBgColor2}" />
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="HeaderGradient" StartPoint="0%,0%" EndPoint="0%,100%">
        <GradientStop Offset="0" Color="{DynamicResource HeaderGrad1}" />
        <GradientStop Offset="1" Color="{DynamicResource HeaderGrad2}" />
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="AccentGradient" StartPoint="0%,0%" EndPoint="100%,100%">
        <GradientStop Offset="0" Color="#2563EB" />
        <GradientStop Offset="1" Color="#1D4ED8" />
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="TealGradient" StartPoint="0%,0%" EndPoint="100%,100%">
        <GradientStop Offset="0" Color="#0EA5A4" />
        <GradientStop Offset="1" Color="#0F766E" />
    </LinearGradientBrush>

    <!-- corner radii / sizing tokens -->
    <CornerRadius x:Key="RadiusSm">8</CornerRadius>
    <CornerRadius x:Key="RadiusMd">12</CornerRadius>
    <CornerRadius x:Key="RadiusLg">16</CornerRadius>
    <CornerRadius x:Key="RadiusPill">24</CornerRadius>
    <x:Double x:Key="FieldHeight">40</x:Double>
    <x:Double x:Key="ControlFontSize">14</x:Double>
</ResourceDictionary>
