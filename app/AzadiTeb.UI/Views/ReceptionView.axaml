<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:AzadiTeb.UI.ViewModels"
             mc:Ignorable="d" d:DesignWidth="1280" d:DesignHeight="820"
             x:Class="AzadiTeb.UI.Views.ReceptionView"
             x:DataType="vm:ReceptionViewModel"
             FlowDirection="RightToLeft"
             FontFamily="{DynamicResource AppFont}">

    <ScrollViewer HorizontalScrollBarVisibility="Disabled"
                  VerticalScrollBarVisibility="Auto"
                  Padding="18">
        <!-- Responsive: two columns on wide screens, single column when narrow -->
        <Grid ColumnDefinitions="* Auto" RowDefinitions="Auto"
              Name="RootGrid" MinWidth="360">

            <!-- ==================== LEFT: main form ==================== -->
            <StackPanel Grid.Column="0" Spacing="16" MaxWidth="900" Margin="0,0,16,0">

                <!-- Patient info card -->
                <Border Classes="card">
                    <StackPanel Spacing="14">
                        <Border Classes="section-head">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <TextBlock Text="&#x1F464;" FontSize="16" VerticalAlignment="Center"/>
                                <TextBlock Classes="section-title" Text="اطلاعات بیمار"/>
                            </StackPanel>
                        </Border>

                        <!-- responsive uniform field grid -->
                        <WrapPanel Orientation="Horizontal">
                            <StackPanel Classes="field" Width="270" Margin="0,0,14,12">
                                <TextBlock Classes="field-label" Text="نام"/>
                                <TextBox Text="{Binding FirstName}" Watermark="نام بیمار"/>
                            </StackPanel>
                            <StackPanel Classes="field" Width="270" Margin="0,0,14,12">
                                <TextBlock Classes="field-label" Text="نام خانوادگی"/>
                                <TextBox Text="{Binding LastName}" Watermark="نام خانوادگی"/>
                            </StackPanel>
                            <StackPanel Classes="field" Width="270" Margin="0,0,14,12">
                                <TextBlock Classes="field-label" Text="کد ملی"/>
                                <TextBox Text="{Binding NationalId}" Watermark="کد ملی ۱۰ رقمی"
                                         Name="NationalIdBox"/>
                            </StackPanel>
                            <StackPanel Classes="field" Width="270" Margin="0,0,14,12">
                                <TextBlock Classes="field-label" Text="نام پدر"/>
                                <TextBox Text="{Binding FatherName}" Watermark="نام پدر"/>
                            </StackPanel>
                            <StackPanel Classes="field" Width="270" Margin="0,0,14,12">
                                <TextBlock Classes="field-label" Text="تاریخ تولد"/>
                                <TextBox Text="{Binding BirthDate}" Watermark="۱۳۷۰/۰۵/۱۲"
                                         Name="BirthDateBox"/>
                            </StackPanel>
                            <StackPanel Classes="field" Width="270" Margin="0,0,14,12">
                                <TextBlock Classes="field-label" Text="جنسیت"/>
                                <ComboBox ItemsSource="{Binding Genders}"
                                          SelectedItem="{Binding SelectedGender}"
                                          HorizontalAlignment="Stretch"/>
                            </StackPanel>
                            <StackPanel Classes="field" Width="270" Margin="0,0,14,12">
                                <TextBlock Classes="field-label" Text="تلفن همراه"/>
                                <TextBox Text="{Binding Mobile}" Watermark="۰۹xxxxxxxxx"/>
                            </StackPanel>
                            <StackPanel Classes="field" Width="270" Margin="0,0,14,12">
                                <TextBlock Classes="field-label" Text="تلفن ثابت"/>
                                <TextBox Text="{Binding Phone}" Watermark="تلفن ثابت"/>
                            </StackPanel>
                            <StackPanel Classes="field" Width="554" Margin="0,0,14,12">
                                <TextBlock Classes="field-label" Text="آدرس"/>
                                <TextBox Text="{Binding Address}" Watermark="آدرس محل سکونت"/>
                            </StackPanel>
                        </WrapPanel>
                    </StackPanel>
                </Border>

                <!-- Insurance & appointment card -->
                <Border Classes="card">
                    <StackPanel Spacing="14">
                        <Border Classes="section-head">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <TextBlock Text="&#x1F6E1;" FontSize="16" VerticalAlignment="Center"/>
                                <TextBlock Classes="section-title" Text="بیمه و نوبت"/>
                            </StackPanel>
                        </Border>

                        <Grid ColumnDefinitions="Auto *" VerticalAlignment="Center">
                            <CheckBox Grid.Column="0" Content="دارای بیمه"
                                      IsChecked="{Binding HasInsurance}" FontWeight="SemiBold"/>
                            <Button Grid.Column="1" Classes="outline" HorizontalAlignment="Left"
                                    Command="{Binding LookupCitizenCommand}"
                                    Content="&#x1F50D;  استعلام بیمه (ثبت احوال)"/>
                        </Grid>
                        <TextBlock Classes="muted" Text="{Binding InsuranceStatus}"/>

                        <WrapPanel Orientation="Horizontal">
                            <StackPanel Width="270" Margin="0,0,14,12">
                                <TextBlock Classes="field-label" Text="بیمه اصلی"/>
                                <ComboBox ItemsSource="{Binding Insurances}"
                                          SelectedItem="{Binding SelectedInsurance}"
                                          IsEnabled="{Binding HasInsurance}"
                                          HorizontalAlignment="Stretch"/>
                            </StackPanel>
                            <StackPanel Width="270" Margin="0,0,14,12">
                                <TextBlock Classes="field-label" Text="بیمه تکمیلی"/>
                                <ComboBox ItemsSource="{Binding Insurances}"
                                          SelectedItem="{Binding SelectedSupplementary}"
                                          HorizontalAlignment="Stretch"/>
                            </StackPanel>
                            <StackPanel Width="270" Margin="0,0,14,12">
                                <TextBlock Classes="field-label" Text="درصد بیمه تکمیلی"/>
                                <NumericUpDown Value="{Binding SupplementaryPercent}"
                                               Minimum="0" Maximum="100" Increment="5"
                                               FormatString="0" MinHeight="40"/>
                            </StackPanel>
                            <StackPanel Width="270" Margin="0,0,14,12">
                                <TextBlock Classes="field-label" Text="نوع بیمار"/>
                                <ComboBox ItemsSource="{Binding PatientKinds}"
                                          SelectedItem="{Binding SelectedPatientKind}"
                                          HorizontalAlignment="Stretch"/>
                            </StackPanel>
                            <StackPanel Width="270" Margin="0,0,14,12">
                                <TextBlock Classes="field-label" Text="نوع نوبت"/>
                                <ComboBox ItemsSource="{Binding VisitKinds}"
                                          SelectedItem="{Binding SelectedVisitKind}"
                                          HorizontalAlignment="Stretch"/>
                            </StackPanel>
                            <StackPanel Width="270" Margin="0,0,14,12">
                                <TextBlock Classes="field-label" Text="شیفت نوبت"/>
                                <ComboBox ItemsSource="{Binding Shifts}"
                                          SelectedItem="{Binding SelectedShift}"
                                          HorizontalAlignment="Stretch"/>
                            </StackPanel>
                        </WrapPanel>
                    </StackPanel>
                </Border>

                <!-- Services card -->
                <Border Classes="card">
                    <StackPanel Spacing="14">
                        <Border Classes="section-head">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <TextBlock Text="&#x1FA7A;" FontSize="16" VerticalAlignment="Center"/>
                                <TextBlock Classes="section-title" Text="خدمات پذیرش"/>
                            </StackPanel>
                        </Border>

                        <!-- add-service row -->
                        <Grid ColumnDefinitions="2* * * 1.3* Auto">
                            <StackPanel Grid.Column="0" Margin="0,0,10,0">
                                <TextBlock Classes="field-label" Text="نام خدمت"/>
                                <TextBox Text="{Binding NewServiceName}" Watermark="مثلاً ویزیت / رادیوگرافی"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1" Margin="0,0,10,0">
                                <TextBlock Classes="field-label" Text="نام پزشک"/>
                                <TextBox Text="{Binding NewServiceDoctor}" Watermark="پزشک"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2" Margin="0,0,10,0">
                                <TextBlock Classes="field-label" Text="انجام‌دهنده"/>
                                <TextBox Text="{Binding NewServicePerformer}" Watermark="اپراتور"/>
                            </StackPanel>
                            <StackPanel Grid.Column="3" Margin="0,0,10,0">
                                <TextBlock Classes="field-label" Text="مبلغ (ریال)"/>
                                <NumericUpDown Value="{Binding NewServiceAmount}" Minimum="0"
                                               Increment="50000" FormatString="#,0" MinHeight="40"/>
                            </StackPanel>
                            <Button Grid.Column="4" Classes="primary" VerticalAlignment="Bottom"
                                    Command="{Binding AddServiceCommand}"
                                    Content="&#x2795;  افزودن خدمت"/>
                        </Grid>

                        <!-- services table -->
                        <Border BorderBrush="{DynamicResource LineBrush}" BorderThickness="1"
                                CornerRadius="10" ClipToBounds="True">
                            <DataGrid ItemsSource="{Binding Services}" AutoGenerateColumns="False"
                                      IsReadOnly="True" MinHeight="120" MaxHeight="260"
                                      CanUserResizeColumns="True" HeadersVisibility="Column"
                                      GridLinesVisibility="Horizontal">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="نام خدمت" Binding="{Binding Name}" Width="2*"/>
                                    <DataGridTextColumn Header="پزشک" Binding="{Binding Doctor}" Width="*"/>
                                    <DataGridTextColumn Header="انجام‌دهنده" Binding="{Binding Performer}" Width="*"/>
                                    <DataGridTextColumn Header="مبلغ" Binding="{Binding AmountText}" Width="1.2*"/>
                                    <DataGridTextColumn Header="سهم بیمار" Binding="{Binding PatientShareText}" Width="1.2*"/>
                                    <DataGridTemplateColumn Header="" Width="70">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <Button Classes="danger" Padding="8,4" Content="حذف"
                                                        HorizontalAlignment="Center"
                                                        Command="{Binding $parent[DataGrid].((vm:ReceptionViewModel)DataContext).RemoveServiceCommand}"
                                                        CommandParameter="{Binding}"/>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                </DataGrid.Columns>
                            </DataGrid>
                        </Border>
                    </StackPanel>
                </Border>

                <!-- Queue card -->
                <Border Classes="card">
                    <StackPanel Spacing="14">
                        <Border Classes="section-head">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <TextBlock Text="&#x1F5C2;" FontSize="16" VerticalAlignment="Center"/>
                                <TextBlock Classes="section-title" Text="صف پذیرش"/>
                            </StackPanel>
                        </Border>
                        <TextBlock Classes="muted" Text="موردی در صف پذیرش نیست."
                                   IsVisible="{Binding QueueEmpty}"/>
                        <Border BorderBrush="{DynamicResource LineBrush}" BorderThickness="1"
                                CornerRadius="10" ClipToBounds="True"
                                IsVisible="{Binding !QueueEmpty}">
                            <DataGrid ItemsSource="{Binding Queue}" AutoGenerateColumns="False"
                                      IsReadOnly="True" MaxHeight="220" HeadersVisibility="Column">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="نوبت" Binding="{Binding TicketNo}" Width="Auto"/>
                                    <DataGridTextColumn Header="بیمار" Binding="{Binding PatientName}" Width="2*"/>
                                    <DataGridTextColumn Header="بیمه" Binding="{Binding Insurance}" Width="*"/>
                                    <DataGridTextColumn Header="ساعت" Binding="{Binding Time}" Width="*"/>
                                    <DataGridTextColumn Header="وضعیت" Binding="{Binding Status}" Width="*"/>
                                </DataGrid.Columns>
                            </DataGrid>
                        </Border>
                    </StackPanel>
                </Border>
            </StackPanel>

            <!-- ==================== RIGHT: bill + actions (sticky) ==================== -->
            <Border Grid.Column="1" Classes="card" Width="330" VerticalAlignment="Top">
                <StackPanel Spacing="16">
                    <Border Classes="section-head">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <TextBlock Text="&#x1F4B0;" FontSize="16" VerticalAlignment="Center"/>
                            <TextBlock Classes="section-title" Text="صدور خودکار قبض"/>
                        </StackPanel>
                    </Border>

                    <StackPanel Spacing="10">
                        <Grid ColumnDefinitions="* Auto">
                            <TextBlock Grid.Column="0" Classes="muted" Text="جمع کل"/>
                            <TextBlock Grid.Column="1" Text="{Binding BillTotalText}" FontWeight="SemiBold"/>
                        </Grid>
                        <Grid ColumnDefinitions="* Auto">
                            <TextBlock Grid.Column="0" Classes="muted" Text="سهم بیمه"/>
                            <TextBlock Grid.Column="1" Text="{Binding BillInsuranceText}"
                                       Foreground="{DynamicResource OkBrush}"/>
                        </Grid>
                        <Grid ColumnDefinitions="* Auto">
                            <TextBlock Grid.Column="0" Classes="muted" Text="سهم بیمه تکمیلی"/>
                            <TextBlock Grid.Column="1" Text="{Binding BillSupplementaryText}"
                                       Foreground="{DynamicResource TealBrush}"/>
                        </Grid>
                        <Grid ColumnDefinitions="* Auto">
                            <TextBlock Grid.Column="0" Classes="muted" Text="تخفیف"/>
                            <TextBlock Grid.Column="1" Text="{Binding BillDiscountText}"
                                       Foreground="{DynamicResource WarnBrush}"/>
                        </Grid>
                        <Rectangle Height="1" Fill="{DynamicResource LineBrush}" Margin="0,4"/>
                        <Border Background="{DynamicResource AccentSoftBrush}" CornerRadius="10" Padding="12">
                            <Grid ColumnDefinitions="* Auto">
                                <TextBlock Grid.Column="0" Text="پرداختی نهایی" FontWeight="Bold"
                                           Foreground="{DynamicResource AccentBrush}" VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="1" Text="{Binding BillPayableText}" FontWeight="Bold"
                                           FontSize="16" Foreground="{DynamicResource AccentBrush}"/>
                            </Grid>
                        </Border>
                    </StackPanel>

                    <StackPanel Spacing="10">
                        <Button Classes="success" HorizontalAlignment="Stretch"
                                Command="{Binding SubmitCommand}"
                                Content="&#x2714;  ثبت پذیرش و صدور قبض"/>
                        <Button Classes="outline" HorizontalAlignment="Stretch"
                                Command="{Binding SubmitNoPayCommand}"
                                Content="افزودن به صندوق نرفته‌ها (بدون پرداخت)"/>
                        <Button Classes="outline" HorizontalAlignment="Stretch"
                                Command="{Binding NewAdmissionCommand}"
                                Content="&#x1F504;  پذیرش جدید (پاک‌کردن فرم)"/>
                    </StackPanel>

                    <Border Background="{DynamicResource PanelAltBrush}" CornerRadius="10" Padding="12">
                        <TextBlock Classes="muted" TextWrapping="Wrap"
                                   Text="مبلغ به‌صورت خودکار بر اساس نوع بیمار، نوع نوبت و بیمهٔ انتخابی محاسبه می‌شود. تمام محاسبات در هستهٔ برنامه انجام می‌گیرد."/>
                    </Border>
                </StackPanel>
            </Border>
        </Grid>
    </ScrollViewer>
</UserControl>
